<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:GestorePassword.UI.Desktop.Templates.Menu">

    <ControlTheme x:Key="{x:Type controls:PasswordGrid}"
                  TargetType="controls:PasswordGrid">
        
        <Setter Property="Template">
            <ControlTemplate>
                <Viewbox Stretch="Uniform">
                    <Border CornerRadius="10"
                            Background="#241623"
                            BorderBrush="#40000000"
                            BorderThickness="2">
                        <Grid>
                            <TextBlock 
                                    Text="I" 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="Black"
                                    FontSize="48"
                                    >
                                
                            </TextBlock>
                        </Grid>
                    </Border>
                </Viewbox>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>