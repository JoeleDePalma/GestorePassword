<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <UserControl
      Height="450"
      Width="800"
      >
      <Border Width="450" Height="50" Classes="PasswordBorder">
      </Border>
    </UserControl>
  </Design.PreviewWith>

  <!-- Button to change the main content of the interface -->
  <Style Selector="Button.ChangeContent">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="VerticalAlignment" Value="Stretch"/>
    <Setter Property="Margin" Value="5, 3"/>
  </Style>

  <Style Selector="Button.ChangeContent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="Background" Value="#30FFFFFF"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Button.ChangeContent:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="Background" Value="#20FFFFFF"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
</Styles>