<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <UserControl
      Height="450"
      Width="800"
      >
      <Border Width="450" Height="50" Classes="PasswordBorder">
      </Border>
    </UserControl>
  </Design.PreviewWith>

  <!-- Button to change the main content of the interface -->
  <Style Selector="Button.ChangeContent">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="VerticalAlignment" Value="Stretch"/>
    <Setter Property="Margin" Value="5, 3"/>
  </Style>

  <Style Selector="Button.ChangeContent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="Background" Value="#30FFFFFF"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Button.ChangeContent:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="Background" Value="#20FFFFFF"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Separator.ContentSeparator">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0%, 50%" EndPoint="100%, 50%">
          <GradientStop Color="Transparent" Offset="0"/>
          <GradientStop Color="#20FFFFFF" Offset="0.25"/>
          <GradientStop Color="#30FFFFFF" Offset="0.5"/>
          <GradientStop Color="#20FFFFFF" Offset="0.75"/>
          <GradientStop Color="Transparent" Offset="1"/>
      </LinearGradientBrush>    
    </Setter>  
  </Style>

  <!--Username TextBox for adding password-->
  <Style Selector="TextBox.AddingPasswordUsernameInput">
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="PlaceholderForeground" Value="#000000"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="CaretBrush" Value="Black"/>
    <Setter Property="SelectionBrush" Value="LightBlue"/>
    <Setter Property="FontFamily" Value="Arial"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style Selector="TextBox.AddingPasswordUsernameInput /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#80101820"/>
    <Setter Property="BorderBrush" Value="#101820"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="CornerRadius" Value="10"/>    
  </Style>

  <Style Selector="TextBox.AddingPasswordUsernameInput:focus-mode /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#80101820"/>
    <Setter Property="BorderBrush" Value="#101820"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="CornerRadius" Value="10"/>    
  </Style>

  <Style Selector="TextBox.AddingPasswordUsernameInput:touch-mode /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#80101820"/>
    <Setter Property="BorderBrush" Value="#101820"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="CornerRadius" Value="15"/>    
  </Style>

  <!--Password TextBox for adding password-->
  <Style Selector="TextBox.AddingPasswordInput">
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="PlaceholderForeground" Value="#000000"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="CaretBrush" Value="Black"/>
    <Setter Property="SelectionBrush" Value="LightBlue"/>
    <Setter Property="FontFamily" Value="Arial"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style Selector="TextBox.AddingPasswordInput /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="15"/>
  </Style>

  <Style Selector="TextBox.AddingPasswordInput:focus-mode /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>   
    <Setter Property="CornerRadius" Value="15"/>
  </Style>

  <Style Selector="TextBox.AddingPasswordInput:touch-mode /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="15"/>
  </Style>

  <!--Button to change visibility of the adding password-->
  <Style Selector="Button.ChangeAddingPasswordVisibilityButtonStyle">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <Style Selector="Button.ChangeAddingPasswordVisibilityButtonStyle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Button.ChangeAddingPasswordVisibilityButtonStyle:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
</Styles>