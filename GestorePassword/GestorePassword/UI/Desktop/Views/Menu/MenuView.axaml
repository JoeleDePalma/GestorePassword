<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:GestorePassword.UI.Desktop.Templates.Menu"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="GestorePassword.UI.Desktop.Views.Menu.MenuView">

    <Grid
        x:Name="MainView"
        >
        <Grid
            ColumnDefinitions="2*, 0.1*, 7*"
            >
            <Grid.Background>
                <LinearGradientBrush StartPoint="0%, 100%" EndPoint="100%, 0%">
                    <GradientStop Color="#87b9f1" Offset="0"/>
                    <GradientStop Color="#6278f5" Offset="1"/>  
                </LinearGradientBrush>
            </Grid.Background>

            <Grid 
                Grid.Column="0"
                RowDefinitions="1*, 0.02*, 0.2*, 3*, 6*, 1*, 0.3*"
                >

                <Viewbox 
                    Grid.Row="0" 
                    HorizontalAlignment="Center"
                    Stretch="Uniform"
                    >

                    <Grid
                        RowDefinitions="0.1*, 1*, 0.1*"
                        ColumnDefinitions="0.1*, 1*, 0.1*"
                        >
                        <StackPanel
                            Orientation="Horizontal"
                            Background="Transparent"
                            Grid.Column="1"
                            Grid.Row="1"
                            Spacing="-5"
                            >
                            <Image
                                Source="avares://GestorePassword/UI/Desktop/Images/VerifiedShield.png"
                                VerticalAlignment="Center"
                                Width="30"
                                Height="30"
                                />  
                            <TextBlock
                                Text="Gestore Password"
                                VerticalAlignment="Center"
                                Foreground="Black"
                                FontWeight="SemiBold"
                                />
                        </StackPanel>
                    </Grid>
                </Viewbox>

                <Border
                    Grid.Row="1"
                    >
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%, 50%" EndPoint="100%, 50%">
                            <GradientStop Color="Transparent" Offset="0"/>    
                            <GradientStop Color="#71b0f8" Offset="0.2"/>
                            <GradientStop Color="#509cf1" Offset="0.3"/>
                            <GradientStop Color="#4c9df8" Offset="0.5"/>
                            <GradientStop Color="#509cf1" Offset="0.8"/>
                            <GradientStop Color="#71b0f8" Offset="0.9"/>  
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid
                    Grid.Row="3"
                    RowDefinitions="*, *, *, 2*"  
                    >
                    <Button
                        Grid.Row="0"
                        Classes="ChangeContent"
                        >
                        <Viewbox>
                            <StackPanel 
                                Orientation="Horizontal"
                                Spacing="5"
                                >
                                <Image 
                                    Source="avares://GestorePassword/UI/Desktop/Images/KeyIcon.png"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Height="35"
                                    Width="35"
                                    >
                                    <Image.RenderTransform>
                                        <RotateTransform Angle="45"/>
                                    </Image.RenderTransform>
                                </Image>
                                <TextBlock
                                    Text="Password"
                                    TextAlignment="Left"
                                    FontWeight="SemiBold"
                                    FontSize="30"
                                    />
                            </StackPanel>
                        </Viewbox>
                    </Button>

                    <Button
                        Grid.Row="1"
                        Classes="ChangeContent"
                        >
                        <Viewbox>
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="5"
                                >
                                <Image
                                    Source="avares://GestorePassword/UI/Desktop/Images/StatisticsIcon.png"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Height="35"
                                    Width="35"
                                    />
                                <TextBlock
                                    Text="Statistiche"
                                    TextAlignment="Left"
                                    FontWeight="SemiBold"
                                    FontSize="30"
                                    />
                            </StackPanel>
                        </Viewbox>
                    </Button>

                    <Button
                        Grid.Row="2"
                        Classes="ChangeContent" 
                        >
                        <Viewbox>
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="5"
                                >
                                <Image
                                    Source="avares://GestorePassword/UI/Desktop/Images/ProfileIcon.png"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Height="35"
                                    Width="35"
                                    />
                                <TextBlock
                                    Text="Profilo"
                                    TextAlignment="Left"
                                    FontWeight="SemiBold"
                                    FontSize="30"
                                    />
                            </StackPanel>
                        </Viewbox>
                    </Button>
                </Grid>

                <Grid
                    Grid.Row="5"
                    >
                    <Border
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="#10FFFFFF"
                        BorderBrush="#20FFFFFF"
                        BorderThickness="2"
                        CornerRadius="10"
                        >
                        <Viewbox
                            HorizontalAlignment="Left"
                            >
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="-5, 0, 0, 0"
                                >
                                <StackPanel.RenderTransform>
                                    <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
                                </StackPanel.RenderTransform>
                                <Border
                                    Background="#5ab3fc"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="12.5"
                                    >
                                    <Viewbox
                                        Height="13"
                                        >
                                        <TextBlock
                                            x:Name="UserInitialTextBlock"
                                            Text="J"
                                            Foreground="Black"
                                            Background="Transparent"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            TextAlignment="Center"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            />    
                                    </Viewbox>
                                </Border>
                                <Viewbox
                                    Height="16"
                                    >
                                    <TextBlock
                                        x:Name="UserUsernameTextBlock"
                                        Text="Jonwen"
                                        Foreground="Black"
                                        Background="Transparent"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        FontFamily="fantasia"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        />
                                </Viewbox>
                            </StackPanel>
                        </Viewbox>
                    </Border>
                </Grid>
            </Grid>

            <Border
                Grid.Column="1"
                Width="1"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Left"
                Margin="2, 0, 0, 0"
                >

                <Border.Background>
                    <LinearGradientBrush StartPoint="50%, 0%" EndPoint="50%, 100%">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.25"/>
                        <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.75"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>   

            <Grid
                x:Name="ContentGrid"
                Grid.Column="2"
                RowDefinitions="1*, 0.1*, 0.1*, 0.15*, 10*"
                >

                <Grid
                    Grid.Row="0"
                    ColumnDefinitions="Auto, *, 0.30*"
                    >

                    <Viewbox
                        HorizontalAlignment="Left"
                        Grid.Column="0"
                        >                    
                        <StackPanel 
                            Orientation="Vertical"
                            Margin="10, 0, 0, 0"
                            >
                            <TextBlock
                                Text="Le tue password"
                                Margin="0, 5, 0, 0"
                                FontFamily="Fantasy"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="#000000"
                                /> 
                            <TextBlock
                                Text="Gestisci le credenziali in modo sicuro"
                                FontFamily="Fantasy"
                                FontSize="12"
                                Foreground="#000000"
                                />
                        </StackPanel>
                    </Viewbox>
                    
                    <Viewbox Grid.Column="2">
                        <Button>
                            <StackPanel 
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Height="30"
                                >
                                <TextBlock
                                    Text="+"
                                    FontSize="16"
                                    VerticalAlignment="Center"
                                    />
                                <TextBlock
                                    Margin="3, 2.5, 0, 0"
                                    Text="Aggiungi"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    />
                            </StackPanel>

                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Width" Value="120"/>
                                    <Setter Property="Height" Value="30"/>
                                    <Setter Property="Margin" Value="0, 5, 10, 0"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Background" Value="#232ED1"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontWeight" Value="DemiBold"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>   
                                
                                <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#1c28d3"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>

                                <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#2430D4"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                    </Viewbox>
                </Grid>

                <Separator Grid.Row="2" VerticalAlignment="Bottom">
                    <Separator.Background>
                        <LinearGradientBrush StartPoint="0%, 50%" EndPoint="100%, 50%">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#20FFFFFF" Offset="0.25"/>
                            <GradientStop Color="#30FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#20FFFFFF" Offset="0.75"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Separator.Background>    
                </Separator>

                <Grid 
                    Grid.Row="4"
                    RowDefinitions="1*, 15*"
                    >
                    <Viewbox
                        Grid.Row="0"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Stretch="Uniform"
                        >
                        <Border
                            Width="900"
                            Background="#70FFFFFF"
                            CornerRadius="25"
                            BorderBrush="#20FFFFFF"
                            BorderThickness="1"
                            >
                            <StackPanel 
                                Orientation="Horizontal"
                                HorizontalAlignment="Stretch"
                                Spacing="-5"
                                >
                                <Image
                                    Source="avares://GestorePassword/UI/Desktop/Images/SearchIcon.png"
                                    Margin="7, 0, 0, 0"
                                    VerticalAlignment="Center"
                                    Height="20"
                                    Width="20"
                                    />
                                <TextBox
                                    x:Name="SearchPasswordTextBox"
                                    PlaceholderForeground="#90000000"
                                    PlaceholderText="Cerca per app o nome utente..."
                                    Foreground="Black"
                                    >
                                    <TextBox.Styles>
                                        <Style Selector="TextBox">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            <Setter Property="Margin" Value="0, 5, 5, 0"></Setter>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>  
                                        
                                        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Style> 

                                        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Style> 
                                    </TextBox.Styles>
                                </TextBox>
                            </StackPanel>
                        </Border>
                    </Viewbox>
                
                    
                        <ScrollViewer
                            Grid.Row="1"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            Margin="0, 10, 0, 0"
                            >
                        <StackPanel
                            x:Name="PasswordStackpanel"
                            Orientation="Vertical"
                            >
                            <Viewbox Stretch="Uniform" Height="40" Width="700">
                                <Border CornerRadius="10"
                                        Background="#273375"
                                        BorderBrush="#40000000"
                                        BorderThickness="2">
                                    <Grid
                                        ColumnDefinitions="Auto, Auto, *, Auto"
                                        >
                                        <Border
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Grid.Column="0"
                                            CornerRadius="5"
                                            Margin="5, 2, 0, 2"
                                            >
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0%, 100%" EndPoint="100%, 0%">
                                                        <GradientStop Color="#6264f8" Offset="0"/>
                                                        <GradientStop Color="#494cf8" Offset="0.5"/>
                                                        <GradientStop Color="#3538f7" Offset="1"/>
                                                    </LinearGradientBrush>    
                                            </Border.Background>

                                            <TextBlock 
                                                x:Name="InitialAppTexBlock"
                                                Text="I" 
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                TextAlignment="Center"
                                                Foreground="Black"
                                                FontWeight="SemiBold"
                                                FontSize="16"
                                                Width="20"
                                                Height="20"
                                                >                                                    
                                            </TextBlock>
                                        </Border>

                                        <StackPanel 
                                            Orientation="Vertical"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Grid.Column="1"
                                            >
                                            <TextBlock
                                                x:Name="PasswordAppNameTextBlock"
                                                Text="Instagram"
                                                Margin="5, 0, 0, 0"
                                                VerticalAlignment="Center"
                                                Foreground="Black"
                                                FontWeight="SemiBold"
                                                FontSize="8"
                                                />

                                            <TextBlock
                                                x:Name="PasswordUsernameTextBlock"
                                                Text="Joele"
                                                Margin="5, 0, 0, 0"
                                                VerticalAlignment="Center"
                                                Foreground="Black"
                                                FontSize="7"
                                                />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            >
                                        
                                            <TextBlock
                                                x:Name="PasswordInfoTextBlock"
                                                Text="PasswordO123."
                                                Margin="5, 0, 0, 0"
                                                VerticalAlignment="Center"
                                                Foreground="Black"
                                                FontFamily="Consolas"
                                                FontWeight="SemiBold"
                                                FontSize="8"
                                                />

                                            <Button
                                                x:Name="ShowPasswordButton"
                                                Background="Transparent"
                                                >
                                                <Image
                                                    Source="avares://GestorePassword/UI/Desktop/Images/closed_eye.png"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Height="15"
                                                    Width="15"
                                                    />    
                                            </Button>

                                            <Button
                                                x:Name="HidePasswordButton"
                                                Background="Transparent"
                                                IsVisible= "False"
                                                >
                                                <Image
                                                    Source="avares://GestorePassword/UI/Desktop/Images/opened_eye.png"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Height="15"
                                                    Width="15"
                                                    />    
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Viewbox>
                        </StackPanel>
                        </ScrollViewer>
                    
                </Grid>
            </Grid>         
        </Grid>
    </Grid>
</UserControl>
