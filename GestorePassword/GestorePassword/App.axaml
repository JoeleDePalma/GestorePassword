<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GestorePassword.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://GestorePassword/UI/Desktop/Templates/Menu/PasswordGrid.axaml"/>
                <ResourceInclude Source="avares://GestorePassword/UI/Desktop/Templates/Menu/StatisticsGrid.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://GestorePassword/UI/Desktop/Styles/User/Access/SignInUpStyles.axaml"/>
        <StyleInclude Source="avares://GestorePassword/UI/Desktop/Styles/Menu/MenuStyles.axaml"/>
        <StyleInclude Source="avares://GestorePassword/UI/Desktop/Styles/Templates/PasswordGridStyles.axaml"/>
    </Application.Styles>

</Application>