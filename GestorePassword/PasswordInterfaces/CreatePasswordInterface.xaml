<UserControl x:Class="GestorePassword.PasswordInterfaces.CreatePasswordInterface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GestorePassword.PasswordInterfaces"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White"
             >
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Viewbox 
            Grid.Column="1" 
            Grid.Row="0"
            Grid.RowSpan="2"
            Stretch="Uniform" 
            StretchDirection="Both"
            >

            <TextBlock
                    Text="Aggiungi una nuova password"
                    Background="Transparent"
                    Foreground="Black"
                    FontFamily="Arial Black"
                    FontWeight="Normal"
                    FontSize="20"
                    TextAlignment="Center"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0, 0, 0, 0"
                    />

        </Viewbox>

        <Separator
            Margin="5, 0, 0, 5"
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            VerticalAlignment="Top"
            />

        <Viewbox
            Stretch="Uniform" 
            StretchDirection="Both"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="4"
            Grid.RowSpan="5"
            HorizontalAlignment="Left"
            >

            <StackPanel
                Orientation="Vertical"
                >

                <StackPanel
                    Orientation="Horizontal"
                    >
                    <TextBlock
                        Text="App: "
                        FontFamily="Arial"
                        FontWeight="Normal"
                        Margin="113, 0, 0, 0"
                        Foreground="Black"
                        />

                    <TextBox 
                        x:Name="AppInput"
                        Style="{StaticResource InfoInput}"/>

                </StackPanel>

                <StackPanel
                    >
                    <TextBlock
                        x:Name="AppErrorBlock"
                        Style="{StaticResource PasswordErrorTextBlock}"
                        />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    >
                    <TextBlock
                        Text="Username (opzionale): "
                        FontFamily="Arial"
                        FontWeight="Normal"
                        Margin="16, 0, 0, 0"
                        Foreground="Black"
                        />

                    <TextBox 
                        x:Name="UsernameInput"
                        Style="{StaticResource InfoInput}"/>

                </StackPanel>

                <StackPanel
                    >
                    <TextBlock
                        x:Name="UsernameErrorBlock"
                        Style="{StaticResource PasswordErrorTextBlock}"
                        />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    >
                    <TextBlock
                        Text="Password: "
                        FontFamily="Arial"
                        FontWeight="Normal"
                        Margin="81, 0, 0, 0"
                        Foreground="Black"
                        />

                    <TextBox 
                        x:Name="ShownPasswordInput"
                        Style="{StaticResource InfoInput}" 
                        Visibility="Collapsed"
                        />
                    
                    <PasswordBox 
                        x:Name="HiddenPasswordInput"
                        Style="{StaticResource InfoInputPassword}" 
                        Visibility="Visible"
                        />

                    <Button 
                        Style="{StaticResource HideOrShowPasswordButton}"
                        x:Name="PasswordModeButton"
                        Click="SwapPasswordMode"
                        ClickMode="Release"
                        >
                        <Image 
                            x:Name="EyeImage"
                            Source="/Images/closed_eye.png"
                            />
                    </Button>

                </StackPanel>

                <StackPanel
                    >
                    <TextBlock
                        x:Name="PasswordErrorBlock"
                        Style="{StaticResource PasswordErrorTextBlock}"
                        />
                </StackPanel>
            </StackPanel>

        </Viewbox>

        <Separator
            Margin="5, 0, 0, 5"
            Grid.Row="11"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            VerticalAlignment="Top"
            />

        <Viewbox 
            Stretch="Uniform" 
            StretchDirection="Both"
            Grid.Column="1"
            Grid.Row="13"
            Grid.RowSpan="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            >

            <StackPanel
                Orientation="Vertical"
                VerticalAlignment="Top"
                >

                <Button
                    x:Name="GeneratePasswordButton"
                    Style="{StaticResource GeneratePasswordOrCancelButton}"
                    Content="Genera password"
                    Width="350"
                    Click="GeneratePassword_Click"
                    ClickMode="Release"
                    />

                <TextBlock/>

                <StackPanel 
                    Orientation="Horizontal"
                    VerticalAlignment="Bottom"
                    >

                    <Button
                        x:Name="SavePasswordButton"
                        Style="{StaticResource SavePasswordButton}"
                        Width="170"
                        Height="25"
                        Click="SavePassword"
                        >

                        <Grid>
                            <StackPanel
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                >
                                <TextBlock
                                    Text="Salva"
                                    />

                                <Image
                                    Margin="10, 0, 0, 0"
                                    Source="/Images/Save.png"
                                    Width="15"
                                    Height="15"
                                    />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Rectangle
                        Width="10"
                        />
                    
                    <Button
                        x:Name="GoBackToMenuButton"
                        Style="{StaticResource GeneratePasswordOrCancelButton}"
                        Content="Annulla"
                        Width="170"
                        Height="25"
                        Click="BackToMenu"
                        ClickMode="Release"
                        />

                </StackPanel>

            </StackPanel>
        </Viewbox>

        <Viewbox
            Grid.Column="1"
            Grid.Row="17"
            >
            <TextBlock
                x:Name="LoadingTextBlock"
                Style="{StaticResource LoadingTextBlockStyle}"
                />
        </Viewbox>
    </Grid>
</UserControl>
