<UserControl x:Class="GestorePassword.MenuInterface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GestorePassword"
             mc:Ignorable="d" 
             d:DesignHeight="480" d:DesignWidth="960"
             Background="White"
             >
    <Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border 
                Grid.Column="0"
                MinWidth="200"
                BorderBrush="Black"
                BorderThickness="1"
                Background="White"
                Visibility="Visible"
                >

                <Viewbox Stretch="Fill" StretchDirection="Both">
                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel 
                            Margin="0,20,0,0" 
                            Grid.Row="0"
                            >

                        <Image 
                            Source="/Images/profile_image.png"
                            Height="70"
                            Width="70"
                            HorizontalAlignment="Center"
                            />

                        <TextBlock 
                            x:Name="UsernamePanelBlock"
                            Margin="0,10,0,0"
                            FontSize="15"
                            FontWeight="Bold"
                            FontStyle="Italic"
                            Text="PREova"
                            HorizontalAlignment="Center"
                            />

                        <TextBlock 
                            x:Name="IdPanelBlock"
                            FontSize="10"
                            Foreground="Gray"
                            Text="ID utente: #103"
                            HorizontalAlignment="Center"
                            />

                        <TextBlock 
                            x:Name="CreatedAtPanelBlock"
                            FontSize="10"
                            Foreground="Gray"
                            Text="Data di creazione: 20/03/2026"
                            HorizontalAlignment="Center"
                            />

                        <Separator Margin="5,15,5,0"/>
                        
                        <StackPanel 
                            Orientation="Horizontal"
                            Margin="5,15,0,0"
                            >

                            <TextBlock 
                                Text="STATISTICHE"
                                FontSize="15"
                                FontWeight="Bold"
                                />

                            <Image 
                                Source="/Images/statistics.png"
                                Width="20"
                                Height="20"
                                Margin="5,0,0,0"
                                />
                        </StackPanel>

                        <TextBlock 
                            x:Name="PasswordsCreatedPanelBlock"
                            Style="{StaticResource StatisticsTextBlocksPanel}"
                            Text="Password salvate: 10"
                            />
                        
                        <TextBlock 
                            x:Name="LastPasswordCreatedAtPanelBlock"
                            Style="{StaticResource StatisticsTextBlocksPanel}"
                            Text="Ultimo salvataggio: 21/03/2026"
                            />
                        
                        <TextBlock 
                            x:Name="LastUpdateAtPanelBlock"
                            Style="{StaticResource StatisticsTextBlocksPanel}"
                            Text="Ultima modifica: 21/03/2026"
                            />
                        
                        <TextBlock 
                            x:Name="LongestPasswordPanelBlock"
                            Style="{StaticResource StatisticsTextBlocksPanel}"
                            Text="Password più lunga: 34 caratteri"
                            />
                        
                        <TextBlock 
                            x:Name="ShortestPasswordPanelBlock"
                            Style="{StaticResource StatisticsTextBlocksPanel}"
                            Text="Password più corta: 6 caratteri"
                            />
                        
                        <TextBlock 
                            x:Name="AveragePasswordLengthPanelBlock"
                            Style="{StaticResource StatisticsTextBlocksPanel}"
                            Text="Lunghezza media: 15 caratteri"
                            />
                    </StackPanel>

                    <StackPanel 
                        Orientation="Horizontal"
                        Grid.Row="1"
                        Margin="0,20,0,0">

                        <Button 
                            Style="{StaticResource StackPanelButton}"
                            ToolTip="Profilo"
                            >

                            <Image 
                                Height="15" 
                                MinWidth="15"
                                Source="/Images/profile_image.png"
                                />
                        </Button>

                        <Button 
                            Style="{StaticResource StackPanelButton}"
                            ToolTip="Impostazioni"
                            >

                            <Image 
                                Height="15" 
                                MinWidth="15"
                                Source="/Images/settings.png"
                                />
                        </Button>

                    </StackPanel>
                    </Grid>
                </Viewbox>
            </Border>

            <ScrollViewer Grid.Column="1"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                >

                <Border 
                    BorderBrush="Black" 
                    BorderThickness="1"
                    >

                    <Viewbox Stretch="Fill" StretchDirection="Both">
                        <StackPanel x:Name="PasswordStackPanel" Orientation="Vertical">
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                            <ContentControl Style="{StaticResource InfoPasswordContent}"/>
                        </StackPanel>
                    </Viewbox>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
