<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Style 
        x:Key="InfoPasswordButton" 
        TargetType="Button"
        >
        
        <Setter Property="Background" Value="LightGray"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="Width" Value="25"/>
        <Setter Property="Height" Value="25"/>
        <Setter Property="Margin" Value="0, 5, 0, 0"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Border x:Name="border"
                            CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            >
                        <ContentPresenter 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
                        
                    </Border>
                    
                </ControlTemplate>
            </Setter.Value>
            
        </Setter>

        <Style.Triggers>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#CECECE"/>
            </Trigger>
            
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#C9C9C9"/>
            </Trigger>
            
        </Style.Triggers>
        
    </Style>

    <Style 
        x:Key="InfoPasswordContent" 
        TargetType="ContentControl">
        
        <Setter Property="Width" Value="560"/>
        <Setter Property="Height" Value="100"/>
        
        <Setter Property="Background" Value="Transparent"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Viewbox 
                        Stretch="Uniform"
                        StretchDirection="Both"
                        DataContext="{TemplateBinding Content}"
                        >
                        <Grid 
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            >

                            <StackPanel
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="10, 0, 0, 0"
                                >

                                <StackPanel
                                    Height="30"
                                    Orientation="Horizontal"
                                    >
                                    <TextBlock
                                        Height="30"
                                        Width="45"
                                        Text="App:"
                                        FontFamily="Arial black"
                                        FontSize="16"
                                        FontWeight="Black"
                                        FontStyle="Normal"
                                        />
                                
                                    <TextBlock
                                        Text="{Binding App}"
                                        Height="30"
                                        MinWidth="100"
                                        FontFamily="Segoe UI Semibold"
                                        FontSize="14"
                                        FontWeight="Normal"
                                        FontStyle="Normal"
                                        />
                                </StackPanel>

                                <StackPanel
                                    Orientation="Horizontal"
                                    Height="30"
                                    >
                                    
                                    <TextBlock
                                        Height="30"
                                        Width="100"
                                        Text="Username:"
                                        FontFamily="Arial black"
                                        FontSize="16"
                                        FontWeight="Black"
                                        FontStyle="Normal"
                                        />

                                    <TextBlock
                                        Text="{Binding Username}"
                                        Height="30"
                                        MinWidth="100"
                                        FontFamily="Segoe UI Semibold"
                                        FontSize="14"
                                        FontWeight="Normal"
                                        FontStyle="Normal"
                                        />
                                </StackPanel>

                                <StackPanel
                                    Orientation="Horizontal"
                                    Height="30"
                                    >
                                    <TextBlock
                                        Height="30"
                                        Width="95"
                                        Text="Password:"
                                        FontFamily="Arial black"
                                        FontSize="16"
                                        FontWeight="Black"
                                        FontStyle="Normal"
                                        />

                                    <TextBlock
                                        Text="{Binding Password}"
                                        Height="30"
                                        MinWidth="100"
                                        FontFamily="Segoe UI Bold"
                                        FontSize="14"
                                        FontWeight="Normal"
                                        FontStyle="Normal"
                                        />
                                </StackPanel>

                            </StackPanel>

                            <StackPanel 
                                Orientation="Vertical" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Right"
                                Height="90"
                                Margin="0, 0, 10, 5"
                                >

                                <Button 
                                    x:Name="ShowPasswordButton"
                                    Style="{StaticResource InfoPasswordButton}"
                                    ToolTip="Mostra"
                                    ClickMode="Release"
                                    >

                                    <Image 
                                            Source="/Images/opened_eye.png" 
                                            Width="20" 
                                            Height="20" 
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Margin="0, 0, 0, 0"
                                            />

                                </Button>

                                <Button 
                                    x:Name="UpdatePasswordButton"
                                    Style="{StaticResource InfoPasswordButton}"
                                    ToolTip="Modifica"
                                    ClickMode="Release"
                                    >

                                    <Image 
                                        Source="/Images/pencil.png" 
                                        Width="20" 
                                        Height="20" 
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Margin="0, 0, 0, 0"
                                        />

                                </Button>

                                <Button 
                                    x:Name="DeletePasswordButton"
                                    Style="{StaticResource InfoPasswordButton}"
                                    ToolTip="Elimina"
                                    ClickMode="Release"
                                    >

                                    <Image 
                                        Source="/Images/trash_can.png" 
                                        Width="20" 
                                        Height="20" 
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Margin="0, 0, 0, 0"
                                        />

                                </Button>

                            </StackPanel>
                        </Grid>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#50D4D4D4"/>
            </Trigger>
            
        </Style.Triggers>
    </Style>

    <Style
        x:Key="StackPanelButton"
        TargetType="Button"
        >

        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Width" Value="100"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#333333"/>

        <Style.Triggers>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#6600C4FF"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Trigger>

            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#3300C4FF"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Trigger>
                
        </Style.Triggers>
    </Style>

    <Style
        x:Key="StatisticsTextBlocksPanel"
        TargetType="TextBlock"
        >

        <Setter Property="Margin" Value="5, 5, 0, 0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style
        x:Key="AddPasswordButton"
        TargetType="Button"
        >

        <Setter Property="Width" Value="250"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="0, 5, 0, 5"/>
        <Setter Property="Content" Value="+"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="LightGray"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Arial"/>
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="ToolTip" Value="Aggiungi Password"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ClickMode" Value="Release"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Border
                        Height="{TemplateBinding Height}"
                        Width="{TemplateBinding Width}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="5"
                        >

                    <ContentPresenter 
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        RecognizesAccessKey="True"
                        />

                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
        <Style.Triggers>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#CECECE"/>
            </Trigger>

            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#C9C9C9"/>
            </Trigger>

        </Style.Triggers>
    </Style>
</ResourceDictionary>