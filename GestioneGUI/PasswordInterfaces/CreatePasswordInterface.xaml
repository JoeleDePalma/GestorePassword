<UserControl x:Class="GestioneGUI.PasswordInterfaces.CreatePassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GestioneGUI.PasswordInterfaces"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White"
             >
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Viewbox 
            Grid.Column="1" 
            Grid.Row="0"
            Grid.RowSpan="2"
            Stretch="Uniform" 
            StretchDirection="Both"
            >

            <TextBlock
                    Text="Aggiungi una nuova password"
                    Background="Transparent"
                    Foreground="Black"
                    FontFamily="Arial Black"
                    FontWeight="Normal"
                    FontSize="20"
                    TextAlignment="Center"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0, 0, 0, 0"
                    />

        </Viewbox>

        <Separator
            Margin="5, 0, 0, 5"
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            VerticalAlignment="Top"
            />

        <Viewbox
            Stretch="Uniform" 
            StretchDirection="Both"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="4"
            Grid.RowSpan="5"
            HorizontalAlignment="Left"
            >

            <StackPanel
                Orientation="Vertical"
                >

                <StackPanel
                    Orientation="Horizontal"
                    >
                    <TextBlock
                        Text="App: "
                        FontFamily="Arial"
                        FontWeight="Normal"
                        Margin="112, 0, 0, 0"
                        />

                    <TextBox Style="{StaticResource InfoInput}"/>

                </StackPanel>

                <StackPanel>
                    <TextBlock/>
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    >
                    <TextBlock
                        Text="Username (opzionale):"
                        FontFamily="Arial"
                        FontWeight="Normal"
                        Margin="19, 0, 0, 0"
                        />

                    <TextBox Style="{StaticResource InfoInput}"/>

                </StackPanel>

                <StackPanel>
                    <TextBlock/>
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    >
                    <TextBlock
                        Text="Password: "
                        FontFamily="Arial"
                        FontWeight="Normal"
                        Margin="81, 0, 0, 0"
                        />

                    <TextBox Style="{StaticResource InfoInput}"/>
                    <PasswordBox Style="{StaticResource InfoInputPassword}" Visibility="Collapsed"/>

                    <Button Style="{StaticResource HideOrShowPasswordButton}">
                        <Image Source="/Images/opened_eye.png"/>
                    </Button>

                </StackPanel>
            </StackPanel>

        </Viewbox>

        <Separator
            Margin="5, 0, 0, 5"
            Grid.Row="11"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            VerticalAlignment="Top"
            />


        <StackPanel
            Grid.Row="13"
            Grid.RowSpan="15"
            Grid.Column="1"
            >

            
        </StackPanel>
    </Grid>
</UserControl>
