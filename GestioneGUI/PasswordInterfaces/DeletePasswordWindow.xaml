<Window x:Class="GestioneGUI.PasswordInterfaces.DeletePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestioneGUI.PasswordInterfaces"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStyle="ToolWindow"
        Title="Conferma eliminazione">

    <Grid
        Height="120"
        Width="330"
        >
        <StackPanel 
            x:Name="DecisionStackPanel"
            Margin="20"
            Visibility="Visible"
            >
            <TextBlock 
                Text="Vuoi davvero eliminare questa password?"
                FontSize="16"
                Margin="0 0 0 20"
                />

            <StackPanel
                Orientation="Horizontal" 
                HorizontalAlignment="Center" 
                >
                <Button 
                    x:Name="DeleteButton" 
                    Content="Elimina" 
                    Width="80" 
                    Margin="10" 
                    Click="DeletePassword"
                    />
            
                <Button 
                    x:Name="GoBackButton"
                    Content="Annulla" 
                    Width="80" 
                    Margin="10" 
                    Click="GoBack"
                    />
            </StackPanel>
        </StackPanel>

        <TextBlock
            x:Name="LoadingTextBlock"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            TextAlignment="Center"
            Visibility="Collapsed"
            FontSize="16"
            FontFamily="Arial"
            FontWeight="Bold"
            FontStyle="Italic"
            Text="Caricamento..."
            />
    </Grid>
</Window>