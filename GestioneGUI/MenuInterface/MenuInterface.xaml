<UserControl x:Class="GestorePassword.MenuInterface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GestorePassword"
             mc:Ignorable="d" 
             d:DesignHeight="480" d:DesignWidth="960"
             Background="White"
             >
    <Grid>

        <Grid
            x:Name="ContentGrid"
            >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0"
                >

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border 
                    Grid.Row="0"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    Background="White"
                    Visibility="Visible"
                    VerticalAlignment="Top"
                    >

                    <Viewbox Stretch="Uniform" StretchDirection="Both">
                        <Grid
                            x:Name="ProfileInfoGrid"
                            Visibility="Visible"
                            >

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel 
                                VerticalAlignment="Top"
                                Margin="0,20,0,0" 
                                Grid.Row="0"
                                >

                                <Image 
                                    Source="/Images/profile_image.png"
                                    Height="70"
                                    Width="70"
                                    HorizontalAlignment="Center"
                                    />

                                <TextBlock 
                                    x:Name="UsernamePanelBlock"
                                    Margin="0,10,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    FontStyle="Italic"
                                    HorizontalAlignment="Center"
                                    Text=""
                                    />

                                <TextBlock 
                                    x:Name="IdPanelBlock"
                                    FontSize="10"
                                    Foreground="Gray"
                                    HorizontalAlignment="Center"
                                    Text=""
                                    />

                                <TextBlock 
                                    x:Name="CreatedAtPanelBlock"
                                    FontSize="10"
                                    Foreground="Gray"
                                    HorizontalAlignment="Center"
                                    Text=""
                                    />

                                <Separator Margin="5,15,5,0"/>

                                <StackPanel 
                                    Orientation="Horizontal"
                                    Margin="5,15,0,0"
                                    >

                                    <TextBlock 
                                        Text="STATISTICHE"
                                        FontSize="15"
                                        FontWeight="Bold"
                                        />

                                    <Image 
                                        Source="/Images/statistics.png"
                                        Width="20"
                                        Height="20"
                                        Margin="5,0,0,0"
                                        />
                                </StackPanel>

                                <TextBlock 
                                    x:Name="PasswordsCreatedPanelBlock"
                                    Style="{StaticResource StatisticsTextBlocksPanel}"
                                    />

                                <TextBlock 
                                    x:Name="LastPasswordCreatedAtPanelBlock"
                                    Style="{StaticResource StatisticsTextBlocksPanel}"
                                    />

                                <TextBlock 
                                    x:Name="LastPasswordUpdatedAtPanelBlock"
                                    Style="{StaticResource StatisticsTextBlocksPanel}"
                                    />

                                <TextBlock 
                                    x:Name="LongestPasswordPanelBlock"
                                    Style="{StaticResource StatisticsTextBlocksPanel}"
                                    />

                                <TextBlock 
                                    x:Name="ShortestPasswordPanelBlock"
                                    Style="{StaticResource StatisticsTextBlocksPanel}"
                                    />

                                <TextBlock 
                                    x:Name="AveragePasswordLengthPanelBlock"
                                    Style="{StaticResource StatisticsTextBlocksPanel}"
                                    />
                            </StackPanel>


                        </Grid>
                    </Viewbox>
                </Border>

                <Border
                    Grid.Row="1"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Background="White"
                    Visibility="Visible"
                    VerticalAlignment="Bottom"
                    >

                    <Viewbox Stretch="Uniform" StretchDirection="Both">
                        <StackPanel 
                            Orientation="Horizontal"
                            Grid.Row="1"
                            Margin="0,0,0,0"
                            VerticalAlignment="Bottom"
                            >

                            <Button 
                                Style="{StaticResource StackPanelButton}"
                                ToolTip="Profilo"
                                >

                                <Image 
                                    Height="15" 
                                    MinWidth="15"
                                    Source="/Images/profile_image.png"
                                    />
                            </Button>

                            <Button 
                                Style="{StaticResource StackPanelButton}"
                                ToolTip="Impostazioni"
                                >

                                <Image 
                                    Height="15" 
                                    MinWidth="15"
                                    Source="/Images/settings.png"
                                    />
                            </Button>

                        </StackPanel>
                    </Viewbox>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="1"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                >

                <Border 
                    BorderBrush="Black" 
                    BorderThickness="1"
                    >

                    <Viewbox Stretch="Uniform" StretchDirection="Both">
                        <StackPanel x:Name="PasswordStackPanel" Orientation="Vertical">
                        </StackPanel>
                    </Viewbox>
                </Border>
            </ScrollViewer>
        </Grid>
        
        <TextBlock
            x:Name="LoadingContentTextBlock"
            Visibility="Collapsed"
            Text="Caricamento..."
            Background="Transparent"
            Foreground="Black"
            Height="40"
            Width="250"
            FontFamily="Sitka Text"
            FontSize="35"
            FontWeight="Bold"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            />
    </Grid>
</UserControl>
